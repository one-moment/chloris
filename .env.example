DATABASE_URL="file:./dev.db"
# Per-company brand for this deployment: onemoment | borough | todaykkot (default: borough).
# Selects workspace name + enabled work modules (crm/reservations are borough-only).
NEXT_PUBLIC_BRAND="borough"
ALLOW_PUBLIC_SIGNUP="true"
STORAGE_PROVIDER="inline"
MAX_UPLOAD_BYTES="10485760"
S3_BUCKET=""
S3_REGION="ap-northeast-2"
S3_ENDPOINT=""
S3_FORCE_PATH_STYLE="false"
S3_PUBLIC_BASE_URL=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# 헤르메스 분류 두뇌의 공급사 스위치(기본 openai). OPENAI_API_KEY가 설정되면 분류·안내가 켜지고,
# 없으면 1단계 안내로 동작(degrade). 키 값은 여기에 쓰지 않는다.
AGENT_LLM_PROVIDER="openai"

# 웹 푸시 (VAPID). `npx web-push generate-vapid-keys`로 1회 생성.
# 공개키는 클라이언트 노출 OK. 비밀키는 .env/Vercel 환경변수에만 — 절대 커밋 금지.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# 팝빌(Popbill) 전자세금계산서/계좌조회/홈택스 연동 — 값은 .env 에만, 커밋 금지
POPBILL_LINK_ID=""
POPBILL_SECRET_KEY=""
POPBILL_CORP_NUM=""
POPBILL_USER_ID=""
POPBILL_IS_TEST="true"
POPBILL_IP_RESTRICT="true"
POPBILL_USE_STATIC_IP="false"
POPBILL_USE_LOCAL_TIME="true"
