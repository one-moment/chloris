  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma generate --schema prisma/schema.postgres.prisma && next build",
    "start": "next start",
    "lint": "eslint \"app/**/*.{js,jsx}\" \"components/**/*.{js,jsx}\" \"lib/**/*.{js,jsx}\" \"modules/**/*.{js,jsx}\" next.config.mjs && node scripts/check-module-boundaries.mjs",
    "db:push": "prisma db push",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:studio": "prisma studio",
    "backup:sqlite": "scripts/backup-sqlite.sh",
    "backup:postgres": "scripts/backup-postgres.sh",
    "purchase-worker": "tsx scripts/purchase-worker/index.ts",
    "purchase-worker:task": "tsx scripts/purchase-worker/run-task.ts",
    "purchase-worker:login:coupang": "tsx scripts/purchase-worker/login.ts coupang",
    "purchase-worker:login:swadpia": "tsx scripts/purchase-worker/login.ts swadpia",
    "purchase-worker:capture": "tsx scripts/purchase-worker/capture.ts",
    "purchase-bot:test": "tsx scripts/test-purchase-bot.mjs",
    "bot-integrations:test": "tsx scripts/test-bot-integrations.mjs",
    "agent-gateway:test": "tsx scripts/test-agent-gateway.mjs",
    "agent-layer:test": "tsx scripts/test-agent-layer.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.18.0",
    "next": "^15.5.18",
    "playwright": "^1.60.0",
    "popbill": "^1.64.2",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
