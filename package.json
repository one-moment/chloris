{
  "name": "mattermost-project-mvp",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma generate --schema prisma/schema.postgres.prisma && next build",
    "start": "next start",
    "lint": "eslint \"app/**/*.{js,jsx}\" \"components/**/*.{js,jsx}\" \"lib/**/*.{js,jsx}\" next.config.mjs",
    "db:push": "prisma db push",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:studio": "prisma studio",
    "backup:sqlite": "scripts/backup-sqlite.sh",
    "backup:postgres": "scripts/backup-postgres.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@prisma/client": "^6.19.3",
    "next": "^15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "prisma": "^6.19.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
