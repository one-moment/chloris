DATABASE_URL="postgresql://postgres.PROJECT_REF:PRISMA_PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

ALLOW_PUBLIC_SIGNUP="false"

STORAGE_PROVIDER="s3"
S3_BUCKET="mattermost-mvp"
S3_REGION="REGION"
S3_ENDPOINT="https://PROJECT_REF.supabase.co/storage/v1/s3"
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL="https://PROJECT_REF.supabase.co/storage/v1/object/public/mattermost-mvp"
MAX_UPLOAD_BYTES="10485760"

AWS_ACCESS_KEY_ID="SUPABASE_STORAGE_ACCESS_KEY"
AWS_SECRET_ACCESS_KEY="SUPABASE_STORAGE_SECRET_KEY"

# 웹 푸시 (VAPID) — Vercel 환경변수에 등록. `npx web-push generate-vapid-keys`로 1회 생성.
# NEXT_PUBLIC_*는 빌드 시 클라이언트에 인라인(공개 OK) → 변경 시 재배포 필요.
# 비밀키는 Vercel 환경변수에만, 깃 커밋 금지. subject는 발송 서명용(web-push 필수).
NEXT_PUBLIC_VAPID_PUBLIC_KEY="VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="VAPID_PRIVATE_KEY"
VAPID_SUBJECT="mailto:admin@1moment.co.kr"
