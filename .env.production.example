APP_DOMAIN=chat.example.com
ACME_EMAIL=admin@example.com

POSTGRES_PASSWORD=replace-with-a-long-random-password
ALLOW_PUBLIC_SIGNUP=false

STORAGE_PROVIDER=s3
S3_BUCKET=replace-with-bucket-name
S3_REGION=ap-northeast-2
S3_PUBLIC_BASE_URL=https://replace-with-bucket-domain.example.com
MAX_UPLOAD_BYTES=10485760

AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
