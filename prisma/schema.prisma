generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String    @id
  name        String
  description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  channels    Channel[]
}

model Channel {
  id        String    @id
  projectId String
  name      String
  type      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
  posts     Post[]
  files     File[]
  botRuns   BotRun[]
}

model User {
  id           String    @id
  email        String    @unique
  name         String
  handle       String    @unique
  passwordHash String
  role         String    @default("member")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  messages     Message[]
  posts        Post[]
  comments     Comment[]
}

model Session {
  id        String   @id
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invite {
  id          String    @id
  codeHash    String    @unique
  email       String?
  role        String    @default("member")
  expiresAt   DateTime?
  usedAt      DateTime?
  usedById    String?
  createdById String?
  createdAt   DateTime  @default(now())
}

model Message {
  id              String   @id
  channelId       String
  authorId        String?
  author          String
  body            String
  attachmentsJson String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  editedAt        DateTime?
  bot             Boolean  @default(false)
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorUser      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([channelId, createdAt(sort: Desc)], map: "idx_messages_channel_created")
}

model PurchaseItem {
  id                      String            @id
  name                    String
  aliasesJson             String
  vendor                  String
  url                     String
  defaultQuantity         Int
  unitLabel               String
  minQuantity             Int
  maxQuantity             Int
  expectedPrice           Int?
  maxAllowedPrice         Int?
  defaultDeliveryMemo     String?
  defaultShippingLocation String?
  approvalRequired        Boolean           @default(true)
  automationLevel         String
  isActive                Boolean           @default(true)
  notes                   String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  requests                PurchaseRequest[]
}

model PurchaseRequest {
  id                  String              @id
  requesterId         String
  channelId           String?
  messageId           String?
  itemId              String
  itemName            String
  vendor              String
  url                 String
  quantity            Int
  unitLabel           String
  expectedPrice       Int?
  maxAllowedPrice     Int?
  shippingLocation    String?
  approvalRequired    Boolean             @default(true)
  approvedBy          String?
  approvedAt          DateTime?
  status              String
  workerTaskId        String?
  resultScreenshotUrl String?
  resultMessage       String?
  orderNumber         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  item                PurchaseItem        @relation(fields: [itemId], references: [id], onDelete: Restrict)
  workerTask          PurchaseWorkerTask?

  @@index([channelId, createdAt(sort: Desc)], map: "idx_purchase_requests_channel_created")
  @@index([status, createdAt], map: "idx_purchase_requests_status_created")
}

model PurchaseWorkerTask {
  id                String          @id
  purchaseRequestId String          @unique
  vendor            String
  url               String
  quantity          Int
  automationLevel   String
  maxAllowedPrice   Int?
  status            String
  resultMessage     String?
  screenshotPath    String?
  observedPrice     Int?
  errorCode         String?
  lockedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([status, createdAt], map: "idx_purchase_worker_tasks_status_created")
}

model Post {
  id              String    @id
  channelId       String
  authorId        String?
  title           String
  body            String
  attachmentsJson String    @default("[]")
  author          String
  status          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  editedAt        DateTime?
  channel         Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorUser      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  comments        Comment[]

  @@index([channelId, createdAt(sort: Desc)], map: "idx_posts_channel_created")
}

model Comment {
  id        String   @id
  postId    String
  authorId  String?
  author    String
  body      String
  mentionsJson String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  editedAt  DateTime?
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorUser User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([postId, createdAt(sort: Asc)], map: "idx_comments_post_created")
}

model File {
  id        String   @id
  channelId String
  name      String
  source    String
  createdAt DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model Bot {
  id           String   @id
  name         String
  provider     String
  command      String
  channelTypes String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BotRun {
  id             String   @id
  channelId      String
  botId          String
  botName        String
  status         String
  approvalStatus String
  summary        String
  payloadJson    String
  createdAt      DateTime @default(now())
  channel        Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}
