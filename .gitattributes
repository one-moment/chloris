# Normalize line endings: store as LF in the repo, check out as LF everywhere.
# Keeps the DELL (Windows) → Mac handoff free of CRLF/LF churn.
* text=auto eol=lf

# Shell scripts must stay LF or they break on macOS/Linux.
*.sh text eol=lf

# Treat known binaries as binary (never normalize).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.zip binary
*.db binary
